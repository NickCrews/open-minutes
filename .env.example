# Which database to target: a name ("local", "prod", ...) resolved via
# DATABASE_URL_<NAME> below, or a full postgres:// URL used verbatim.
# Every entrypoint honors it, e.g. `DB=prod pnpm db:migrate`, `DB=prod pnpm dev`.
# Usually passed per-command rather than set here.
#
# "local" (the default) needs no configuration: it targets docker-compose's
# postgres. Set DATABASE_URL_LOCAL only to point "local" somewhere else.
#DB=local

#DATABASE_URL_PROD=postgres://user:password@host/dbname?sslmode=require

NODE_ENV=development
VITE_PUBLIC_API_URL=http://localhost:3000
