{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "format": "prettier --experimental-cli --ignore-unknown '**/*' --write",
    "format:check": "prettier --experimental-cli --ignore-unknown '**/*' --check",
    "lint": "eslint .",
    "test": "vitest run",
    "test:slow": "SLOW=1 vitest run --tagsFilter slow",
    "test:all": "SLOW=1 vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run format:check && pnpm run lint && pnpm run test",
    "db:generate": "pnpm --filter @open-minutes/core run db:generate",
    "db:migrate": "pnpm --filter @open-minutes/core run db:migrate",
    "db:nuke": "pnpm --filter @open-minutes/core run db:nuke",
    "db:seed": "pnpm --filter @open-minutes/pipeline run db:seed",
    "db:reset": "pnpm db:nuke && pnpm db:seed",
    "pipeline:fixtures": "pnpm --filter @open-minutes/pipeline run fixtures"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@eslint/js": "^9.36.0",
    "eslint": "^9.36.0",
    "prettier": "^3.7.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.45.0",
    "vitest": "^4.0.18"
  }
}
