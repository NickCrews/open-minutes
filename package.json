{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "format": "prettier --experimental-cli --ignore-unknown '**/*' --write",
    "format:check": "prettier --experimental-cli --ignore-unknown '**/*' --check",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "pnpm run format:check && pnpm run lint && pnpm run test",
    "db:setup": "pnpm --filter gbos-core run db:setup",
    "pipeline:fixtures": "pnpm --filter gbos-pipeline run fixtures"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@eslint/js": "^9.36.0",
    "eslint": "^9.36.0",
    "prettier": "^3.7.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.45.0",
    "vitest": "^4.0.18"
  }
}
